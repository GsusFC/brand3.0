{% extends "base.html.j2" %}
{% block title %}brand3 :: {{ model.title }}{% endblock %}
{% block extra_head %}
<script src="/static/perceptual_narrative_comparison.js?v=brand3-perceptual-comparison-20260515" defer></script>
{% endblock %}
{% block content %}
<section>
  <div class="section-head">
    <span class="label">brand3_lab</span>
    <span class="tag">// experimental · comparison only · no persistence</span>
  </div>

  <h1 class="page-title">{{ model.title }}</h1>
  <p class="prose dim intro-copy">{{ model.intro }}</p>

  <div class="guardrail-banner">
    <strong>Draft-only review surface.</strong>
    <span class="dim">This route reads static evaluation artifacts, does not persist reviewer choices, and does not alter scoring, prompts, reports, or Visual Signature.</span>
  </div>

  <div class="badge-line">
    {% for guardrail in model.guardrails %}
    <span class="badge">{{ guardrail }}</span>
    {% endfor %}
  </div>
</section>

<hr class="rule-thin">

<section>
  <div class="section-head">
    <span class="label">case_selector</span>
    <span class="tag">// {{ model.pair_count }} paired examples visible</span>
  </div>

  <div class="lab-toolbar">
    <label class="lab-selector">
      <span>Brand</span>
      <select data-comparison-brand-selector>
        <option value="all">All six examples</option>
        {% for pair in model.pairs %}
        <option value="{{ pair.id }}">{{ pair.brand }}</option>
        {% endfor %}
      </select>
    </label>
    <div class="lab-toolbar-meta">
      <span class="inline-kv"><span class="k">pairs</span>=<span class="v">{{ model.pair_count }}</span></span>
      <span class="inline-kv"><span class="k">mode</span>=<span class="v">local draft</span></span>
      <span class="inline-kv"><span class="k">storage</span>=<span class="v">none</span></span>
    </div>
  </div>
</section>

<hr class="rule-thin">

<section>
  <div class="section-head">
    <span class="label">paired_narratives</span>
    <span class="tag">// baseline vs perceptual</span>
  </div>

  <form class="comparison-review-form" data-perceptual-comparison-form>
    <div class="comparison-list">
      {% for pair in model.pairs %}
      <article class="comparison-card" id="pair-{{ pair.id }}" data-comparison-pair data-brand-id="{{ pair.id }}" data-brand-name="{{ pair.brand }}">
        <div class="comparison-card-head">
          <div>
            <h2>{{ pair.brand }}</h2>
            <p class="dim">Brand3/FLOC* confidence: {{ pair.brand3_confidence|replace('_', ' ') }}</p>
          </div>
          <span class="badge">case {{ pair.index }}</span>
        </div>

        <div class="comparison-grid">
          <div class="narrative-panel baseline-panel">
            <div class="panel-head">
              <span class="label">baseline narrative</span>
              <span class="badge">current</span>
            </div>
            <p>{{ pair.baseline_narrative }}</p>
          </div>
          <div class="narrative-panel perceptual-panel">
            <div class="panel-head">
              <span class="label">perceptual narrative</span>
              <span class="badge badge-ready">experimental</span>
            </div>
            <p>{{ pair.perceptual_augmented_narrative }}</p>
          </div>
        </div>

        <div class="highlight-grid">
          <div class="highlight-box">
            <h3>Better specificity</h3>
            <ul>
              {% for item in pair.better_specificity %}
              <li>{{ item }}</li>
              {% endfor %}
            </ul>
          </div>
          <div class="highlight-box">
            <h3>Perceptual gains</h3>
            <ul>
              {% for item in pair.perceptual_gains %}
              <li>{{ item }}</li>
              {% endfor %}
            </ul>
          </div>
          <div class="highlight-box risk-box">
            <h3>Overreach risks</h3>
            <ul>
              {% for item in pair.overreach_risks %}
              <li>{{ item }}</li>
              {% endfor %}
            </ul>
          </div>
          <div class="highlight-box generic-box">
            <h3>Generic phrases</h3>
            {% if pair.generic_phrases %}
            <div class="phrase-row">
              {% for phrase in pair.generic_phrases %}
              <span class="badge">{{ phrase }}</span>
              {% endfor %}
            </div>
            {% else %}
            <p class="dim">No tracked generic phrase detected.</p>
            {% endif %}
          </div>
        </div>

        <fieldset class="review-control-group">
          <legend>Reviewer decision</legend>
          {% for option in model.review_options %}
          <label class="choice-pill">
            <input type="radio" name="decision_{{ pair.id }}" value="{{ option }}">
            <span>{{ option|replace('_', ' ') }}</span>
          </label>
          {% endfor %}
        </fieldset>

        <label class="comparison-notes">
          <span>Reviewer notes</span>
          <textarea name="notes_{{ pair.id }}" data-notes-for="{{ pair.id }}" placeholder="Evidence-based note. Do not treat this as an official record."></textarea>
        </label>
      </article>
      {% endfor %}
    </div>

    <div class="draft-actions comparison-export-actions">
      <button class="button" type="button" data-export-comparison-draft>Export local draft JSON</button>
      <span class="draft-export-status" data-comparison-export-status aria-live="polite"></span>
    </div>
  </form>
</section>

<hr class="rule-thin">

<section>
  <div class="section-head">
    <span class="label">deployment_context</span>
    <span class="tag">// from stress test and overreach taxonomy</span>
  </div>

  <div class="deployment-grid">
    <article class="deployment-panel">
      <h2>Safe deployment zones</h2>
      <ul>
        {% for item in model.safe_deployment_zones %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </article>
    <article class="deployment-panel risk-box">
      <h2>Unsafe deployment zones</h2>
      <ul>
        {% for item in model.unsafe_deployment_zones %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </article>
  </div>
</section>

<hr class="rule-thin">

<section>
  <div class="section-head">
    <span class="label">overreach_taxonomy</span>
    <span class="tag">// warning signs</span>
  </div>

  <div class="failure-mode-grid">
    {% for mode in model.failure_modes %}
    <details class="failure-mode-card">
      <summary>
        <span>{{ mode.name }}</span>
        <span class="badge">{{ mode.id }}</span>
      </summary>
      <ul>
        {% for sign in mode.warning_signs %}
        <li>{{ sign }}</li>
        {% endfor %}
      </ul>
    </details>
    {% endfor %}
  </div>
</section>

<hr class="rule-thin">

<section>
  <div class="section-head">
    <span class="label">source_artifacts</span>
    <span class="tag">// static inputs</span>
  </div>
  <div class="kv artifact-kv">
    {% for path in model.source_paths %}
    <span class="k">source</span>    <span class="v mono-token">{{ path }}</span>
    {% endfor %}
  </div>
</section>
{% endblock %}
