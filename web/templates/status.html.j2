{% extends "base.html.j2" %}
{% block title %}brand3 :: analyzing {{ brand_slug }}{% endblock %}
{% block extra_head %}
  {% if status in ("queued", "running") %}
  <meta http-equiv="refresh" content="5">
  {% endif %}
{% endblock %}
{% block content %}
<section>
  <div class="section-head">
    <span class="label">analysis_status</span>
    <span class="tag">// token={{ token }}</span>
  </div>

  <pre class="term-head">
{%- if status == "queued" -%}
<span class="hl-warn">[queued]</span>   <span class="dim">{{ brand_slug }} — waiting for worker</span>
{%- elif status == "running" -%}
<span class="hl-accent">[running]</span>  <span class="dim">{{ brand_slug }} — {{ phase_label }}</span>
{%- elif status == "ready" -%}
<span class="hl-ok">[ready]</span>    <span class="dim">{{ brand_slug }} — redirecting to report ...</span>
{%- elif status == "failed" -%}
<span class="hl-alert">[failed]</span>   <span class="dim">{{ brand_slug }} — {{ error_message or "unknown error" }}</span>
{%- endif -%}
  </pre>

  {% if status in ("queued", "running") %}
  <div class="matrix-loader phase-{{ phase }}" aria-hidden="true">
    {% for row in range(4) %}
    <div class="matrix-row">
      {% for col in range(320) %}
      <span class="matrix-dot"></span>
      {% endfor %}
    </div>
    {% endfor %}
  </div>

  <div class="status-grid">
    <div class="status-metric">
      <span class="k">phase</span>
      <span class="v">{{ phase_label }}</span>
    </div>
    <div class="status-metric">
      <span class="k">elapsed</span>
      <span class="v">{{ elapsed_label }}</span>
    </div>
    <div class="status-metric">
      <span class="k">typical run</span>
      <span class="v">2–4 min</span>
    </div>
  </div>

  <ol class="status-steps">
    {% for step in phase_steps %}
    <li class="status-step is-{{ step.state }}">
      <span class="status-step-mark">
        {%- if step.state == "done" -%}[done]
        {%- elif step.state == "active" -%}[active]
        {%- elif step.state == "failed" -%}[failed]
        {%- else -%}[pending]
        {%- endif -%}
      </span>
      <span>{{ step.label }}</span>
    </li>
    {% endfor %}
  </ol>

  <p class="small dim">Page auto-refreshes every 5 seconds. This checklist reflects pipeline phase, not a percentage estimate.</p>
  {% elif status == "ready" %}
  <p><a href="/r/{{ token }}">→ open report</a></p>
  {% elif status == "failed" %}
  <p><a href="/">← back to form</a></p>
  {% endif %}
</section>
{% endblock %}
