{% extends "base.html.j2" %}
{% block title %}Brand3 — brand audit{% endblock %}
{% block content %}
<section>
  <div class="section-head">
    <span class="label">brand_audit</span>
    <span class="tag">// primary product · scoring first</span>
  </div>

  <h1 class="page-title">brand3 — brand audit</h1>
  <p class="prose dim intro-copy">
    Brand3 Scoring is the working audit product. Paste a URL to generate a public brand audit with dimension scores, report prose, and listed results.
  </p>

  <form action="/analyze" method="post" class="form-row">
    <input type="url" name="url" placeholder="https://your-brand.com" required autofocus spellcheck="false" autocomplete="off">
    <button type="submit">run brand audit</button>
  </form>

  <p class="small dim form-note">
    Brand Audit produces dimension scores, public report prose, and a shareable result page. Limit: 5 analyses per IP every 24h · FLOC team: <a href="/team/unlock?token=...">/team/unlock?token=...</a>
  </p>

  <div class="home-feature-strip">
    <article class="home-feature">
      <h2>Dimension scores</h2>
      <p>See the five scoring dimensions and the rendered explanation that comes with each analysis.</p>
    </article>
    <article class="home-feature">
      <h2>Reports</h2>
      <p>Open the public observatory and per-brand report pages from the same product surface.</p>
    </article>
    <article class="home-feature home-feature-lab">
      <h2>Visual Signature Lab</h2>
      <p>Secondary research area for evidence-only human visual perception. Accessible, but not foregrounded.</p>
      <a class="source-link" href="/visual-signature">open lab</a>
    </article>
  </div>
</section>

<hr class="rule-thin">

<section>
  <div class="section-head">
    <span class="label">latest_brand_audits</span>
    <span class="tag">// last {{ latest_analyses|length }} public</span>
  </div>
  {% if latest_analyses %}
  <div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th class="col-date">date</th>
        <th class="col-brand">brand</th>
        <th class="num col-score">score</th>
        <th class="col-bar">bar</th>
        <th class="col-band">band</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
    {% for row in latest_analyses %}
      <tr>
        <td>{{ row.date }}</td>
        <td><a href="/brand/{{ row.brand_slug }}">{{ row.brand_slug }}</a></td>
        <td class="num num-inline">{{ row.score_display }}</td>
        <td class="bar">{{ row.bar }}</td>
        <td class="dim">{{ row.band }}</td>
        <td><a href="/r/{{ row.token }}">view</a></td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  </div>
  <p class="small dim block-note"><a href="/reports">→ browse full reports</a> · <a href="/visual-signature">Visual Signature Lab</a></p>
  {% else %}
  <div class="empty">// no public audits yet — submit the first one above.</div>
  {% endif %}
</section>
{% endblock %}
