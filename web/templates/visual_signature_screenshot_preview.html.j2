{% extends "base.html.j2" %}
{% block title %}brand3 :: {{ model.title }}{% endblock %}
{% block content %}
<section>
  <div class="section-head">
    <span class="label">screenshot_preview</span>
    <span class="tag">// in-site visual evidence</span>
  </div>

  <h1 class="page-title">{{ model.brand_name }}</h1>
  <p class="prose dim intro-copy vs-summary">
    {{ model.screenshot_type }} screenshot preview. Visual Signature Lab remains read-only, evidence-only, and separate from Brand3 Scoring.
  </p>

  <nav class="vs-nav" aria-label="Visual Signature sections">
    {% for item in model.nav %}
    <a class="vs-nav-link{% if item.active %} active{% endif %}" href="{{ item.href }}">{{ item.label }}</a>
    {% endfor %}
  </nav>

  <div class="badge-line">
    <span class="badge badge-{{ model.capture_status|replace('_', '-') }}">{{ model.capture_status }}</span>
    <span class="badge">{{ model.screenshot_type }}</span>
    <span class="badge">{{ model.obstruction_type }}</span>
    <span class="badge">{{ model.obstruction_severity }}</span>
    <span class="badge">{{ model.perceptual_state }}</span>
  </div>

  <nav class="preview-step-nav" aria-label="Related screenshot navigation">
    {% if model.previous %}
    <a class="source-link" href="{{ model.previous.preview_href }}">Previous: {{ model.previous.label }}</a>
    {% else %}
    <span class="source-link is-disabled">Previous</span>
    {% endif %}
    <a class="source-link" href="/visual-signature">Back to overview</a>
    {% if model.next %}
    <a class="source-link" href="{{ model.next.preview_href }}">Next: {{ model.next.label }}</a>
    {% else %}
    <span class="source-link is-disabled">Next</span>
    {% endif %}
  </nav>
</section>

<hr class="rule-thin">

<section class="screenshot-preview-section">
  <div class="section-head">
    <span class="label">preview</span>
    <span class="tag">// {{ model.selected.filename }}</span>
  </div>

  <figure class="screenshot-preview-frame{% if model.screenshot_type == 'full page' %} is-full-page{% endif %}">
    <input class="preview-mode-input" type="radio" name="preview-mode" id="preview-fit-viewport" checked>
    <input class="preview-mode-input" type="radio" name="preview-mode" id="preview-actual-size">

    <div class="preview-toolbar">
      <span class="preview-viewport-label">Simulated viewport: 1440 &times; 1024</span>
      <div class="preview-actions" role="group" aria-label="Screenshot preview mode">
        <label class="source-link preview-mode-action preview-fit-action" for="preview-fit-viewport">Fit viewport</label>
        <label class="source-link preview-mode-action preview-actual-action" for="preview-actual-size">Actual size</label>
        <a class="source-link" href="{{ model.selected.href }}" target="_blank" rel="noopener">Open full-resolution image</a>
      </div>
    </div>

    <div class="screenshot-preview-viewport">
      <img class="screenshot-preview-image" src="{{ model.selected.href }}" alt="{{ model.selected.alt }}">
    </div>
    <figcaption>
      <span>{{ model.screenshot_type }}</span>
      <code>{{ model.selected.filename }}</code>
    </figcaption>
  </figure>
</section>

<hr class="rule-thin">

<section>
  <div class="section-head">
    <span class="label">related_captures</span>
    <span class="tag">// same brand</span>
  </div>

  <div class="related-screenshots" role="list">
    {% for screenshot in model.related %}
    <article class="related-screenshot{% if not screenshot.exists %} is-missing{% endif %}{% if screenshot.is_current %} is-current{% endif %}" role="listitem">
      <div>
        <h2>{{ screenshot.label }}</h2>
        <code>{{ screenshot.filename }}</code>
      </div>
      {% if screenshot.exists %}
      {% if screenshot.is_current %}
      <span class="badge">current</span>
      {% else %}
      <a class="source-link" href="{{ screenshot.preview_href }}">preview</a>
      {% endif %}
      {% else %}
      <span class="dim">{% if screenshot.label == "clean attempt" %}No clean attempt available{% else %}missing screenshot{% endif %}</span>
      {% endif %}
    </article>
    {% endfor %}
  </div>
</section>

<hr class="rule-thin">

<section>
  <div class="section-head">
    <span class="label">evidence_context</span>
    <span class="tag">// metadata collapsed</span>
  </div>

  {% if model.evidence_notes %}
  <details class="artifact-details">
    <summary>
      <span>evidence notes</span>
      <span class="badge">available</span>
    </summary>
    <ul class="evidence-notes">
      {% for note in model.evidence_notes %}
      <li>{{ note }}</li>
      {% endfor %}
    </ul>
  </details>
  {% endif %}

  <div class="artifact-list">
    {% for artifact in model.source_artifacts %}
    <details class="artifact-details">
      <summary>
        <span>{{ artifact.label }}</span>
        <span class="badge">{% if artifact.raw_json %}available{% else %}missing_or_unknown{% endif %}</span>
      </summary>
      <div class="kv artifact-kv">
        <span class="k">path</span>    <span class="v mono-token">{{ artifact.path }}</span>
        <span class="k">source</span>  <span class="v"><a href="{{ artifact.href }}">open source artifact</a></span>
      </div>
      {% if artifact.raw_json %}
      <pre class="raw-json">{{ artifact.raw_json }}</pre>
      {% else %}
      <pre class="raw-json">No matching source row was found for this brand.</pre>
      {% endif %}
    </details>
    {% endfor %}
  </div>
</section>
{% endblock %}
