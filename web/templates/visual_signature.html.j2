{% extends "base.html.j2" %}
{% block title %}brand3 :: {{ model.title }}{% endblock %}
{% block content %}
<section>
  <div class="section-head">
    <span class="label">{{ model.title }}</span>
    <span class="tag">// read-only · evidence-only · no scoring impact</span>
  </div>

  <h1 class="page-title">{{ model.title }}</h1>
  <p class="prose dim intro-copy vs-summary">{{ model.intro }}</p>

  <nav class="vs-nav" aria-label="Visual Signature sections">
    {% for item in model.nav %}
    <a class="vs-nav-link{% if item.active %} active{% endif %}" href="{{ item.href }}">{{ item.label }}</a>
    {% endfor %}
  </nav>

  <div class="guardrail-banner">
    <strong>Brand3 Scoring remains separate.</strong>
    <span class="dim">New brand scans still run through <a href="{{ model.initial_scoring.href }}">Brand Audit</a>. Dimension prose is render-time derived by the current report renderer; no persisted generated_texts_per_dimension artifact is invented here.</span>
  </div>

  <div class="badge-line">
    {% for guardrail in model.guardrails %}
    <span class="badge">{{ guardrail }}</span>
    {% endfor %}
  </div>
</section>

{% if model.section == "overview" %}
<hr class="rule-thin">

<section>
  <div class="section-head">
    <span class="label">visual_evidence</span>
    <span class="tag">// screenshots are primary evidence</span>
  </div>

  <div class="visual-evidence-intro">
    <h2>Visual evidence first</h2>
    <p>Each capture keeps the raw viewport as primary evidence. Clean attempts and full-page captures are supplemental views for understanding obstruction, dismissal behavior, and what changed without reading raw JSON.</p>
    <div class="vs-meta-row">
      <span class="inline-kv"><span class="k">captures</span>=<span class="v">{{ model.visual_evidence.summary.capture_count }}</span></span>
      <span class="inline-kv"><span class="k">raw viewport</span>=<span class="v">{{ model.visual_evidence.summary.raw_viewport_count }}</span></span>
      <span class="inline-kv"><span class="k">clean attempt</span>=<span class="v">{{ model.visual_evidence.summary.clean_attempt_count }}</span></span>
      <span class="inline-kv"><span class="k">full page</span>=<span class="v">{{ model.visual_evidence.summary.full_page_count }}</span></span>
    </div>
  </div>

  <div class="visual-evidence-list">
    {% for item in model.visual_evidence["items"] %}
    <article class="visual-evidence-item">
      <div class="visual-evidence-head">
        <div>
          <h2>{{ item.brand_name }}</h2>
          <p class="dim">
            {{ item.obstruction_type }} · {{ item.obstruction_severity }} · {{ item.perceptual_state }}
          </p>
        </div>
        <span class="badge badge-{{ item.capture_status|replace('_', '-') }}">{{ item.capture_status }}</span>
      </div>

      <div class="screenshot-strip">
        {% for screenshot in item.variants %}
        <figure class="screenshot-evidence{% if not screenshot.exists %} is-missing{% endif %}">
          {% if screenshot.exists %}
          <a href="{{ screenshot.preview_href }}" aria-label="Preview {{ screenshot.label }} screenshot for {{ item.brand_name }}">
            <img src="{{ screenshot.href }}" alt="{{ screenshot.alt }}">
          </a>
          {% else %}
          <div class="screenshot-missing">{% if screenshot.label == "clean attempt" %}No clean attempt available{% else %}missing screenshot{% endif %}</div>
          {% endif %}
          <figcaption>
            <span>{{ screenshot.label }}</span>
            <code>{{ screenshot.filename }}</code>
            {% if screenshot.exists %}
            <a class="source-link screenshot-source-link" href="{{ screenshot.href }}" target="_blank" rel="noopener">open full-resolution</a>
            {% endif %}
          </figcaption>
        </figure>
        {% endfor %}
      </div>

      <div class="evidence-story">
        <p><strong>Capture:</strong> raw viewport is preserved as the evidence baseline.</p>
        <p><strong>Obstruction:</strong> {{ item.obstruction_type }} was recorded with {{ item.obstruction_severity }} severity.</p>
        <p><strong>Clean attempt:</strong> {% if item.dismissal_attempted %}a safe dismissal attempt was recorded{% if item.dismissal_successful %} and reduced the obstruction{% else %}, but it did not materially reduce the obstruction{% endif %}.{% else %}no dismissal was attempted for this capture.{% endif %}</p>
        <p><strong>Preservation:</strong> supplemental captures do not replace the raw viewport.</p>
      </div>

      {% if item.evidence_notes %}
      <details class="vs-compact-details">
        <summary>evidence notes</summary>
        <ul class="evidence-notes">
          {% for note in item.evidence_notes %}
          <li>{{ note }}</li>
          {% endfor %}
        </ul>
      </details>
      {% endif %}
    </article>
    {% endfor %}

    {% if not model.visual_evidence["items"] %}
    <div class="visual-evidence-empty">
      No curated screenshots were found under <code>examples/visual_signature/screenshots/</code>.
    </div>
    {% endif %}
  </div>
</section>

<hr class="rule-thin">

<section>
  <div class="section-head">
    <span class="label">evidence_flow</span>
    <span class="tag">// capture to review</span>
  </div>
  <div class="evidence-flow">
    <article>
      <h2>1. Capture</h2>
      <p>The viewport screenshot records the page as observed. This is the baseline artifact used for evidence review.</p>
    </article>
    <article>
      <h2>2. Obstruction dismissal</h2>
      <p>When a safe candidate exists, the system can record an attempted dismissal. Unsafe or ambiguous actions remain blocked.</p>
    </article>
    <article>
      <h2>3. Clean attempt</h2>
      <p>A clean-attempt image is supplemental. It helps compare what changed, but it does not overwrite the raw capture.</p>
    </article>
    <article>
      <h2>4. Evidence preservation</h2>
      <p>Raw, clean-attempt, full-page, manifest, and audit artifacts stay linked so reviewers can inspect the lineage.</p>
    </article>
  </div>
</section>
{% endif %}

<hr class="rule-thin">

<section>
  <div class="section-head">
    <span class="label">{% if model.section == "overview" %}governance_calibration_reviewer_summary{% else %}status_summary{% endif %}</span>
    <span class="tag">// source artifacts only</span>
  </div>

  <div class="vs-report-list">
    {% for card in model.cards %}
    <article class="vs-report-item">
      <div class="vs-report-main">
        <div class="vs-report-title">
          <h2>{{ card.label }}</h2>
          <p class="dim">
            {% if card.exists %}
            Source artifact is available for local review.
            {% else %}
            Source artifact is missing or unknown; the platform keeps rendering without it.
            {% endif %}
          </p>
        </div>
        <span class="badge badge-{{ card.status|replace('_', '-') }}">{{ card.status }}</span>
      </div>

      <div class="vs-meta-row">
        {% for key, value in card.summary.items() %}
        <span class="inline-kv"><span class="k">{{ key }}</span>=<span class="v">{{ value }}</span></span>
        {% endfor %}
        {% if not card.summary %}
        <span class="inline-kv"><span class="k">state</span>=<span class="v">missing_or_unknown</span></span>
        {% endif %}
      </div>

      <details class="vs-compact-details">
        <summary>artifact metadata</summary>
        <div class="kv artifact-kv">
          <span class="k">type</span>    <span class="v">{{ card.type }}</span>
          <span class="k">exists</span>  <span class="v">{{ card.exists }}</span>
          <span class="k">path</span>    <span class="v mono-token">{{ card.path }}</span>
          <span class="k">source</span>  <span class="v">{% if card.exists %}<a href="{{ card.source_href }}">open source {{ card.type }}</a>{% else %}missing_or_unknown{% endif %}</span>
        </div>
      </details>
    </article>
    {% endfor %}
  </div>
</section>

{% if model.section == "reviewer" %}
<hr class="rule-thin">

<section>
  <div class="section-head">
    <span class="label">human_review</span>
    <span class="tag">// screenshot first · local-only draft</span>
  </div>
  <div class="vs-report-item">
    <div class="vs-report-main">
      <div class="vs-report-title">
        <h2>Evidence-first human review</h2>
        <p class="dim">Inspect Headspace and Allbirds screenshots, answer structured visual questions, and draft outcome/confidence/notes without creating completed review records.</p>
      </div>
      <a class="source-link" href="/visual-signature/reviewer/human-review">open human review</a>
    </div>
  </div>
</section>
{% endif %}

{% if model.records %}
<hr class="rule-thin">
<section>
  <div class="section-head">
    <span class="label">records</span>
    <span class="tag">// {{ model.records|length }} shown</span>
  </div>
  <div class="table-wrap vs-records-table">
    <table>
      <thead>
        <tr>
          <th>item</th>
          <th>status</th>
          <th>metadata</th>
        </tr>
      </thead>
      <tbody>
      {% for item in model.records %}
        <tr>
          <td>{{ item.title }}</td>
          <td><span class="badge">{{ item.status }}</span></td>
          <td>
            {% for key, value in item.meta.items() %}
              <span class="inline-kv"><span class="k">{{ key }}</span>=<span class="v">{{ value }}</span></span>
            {% endfor %}
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
</section>
{% endif %}

<hr class="rule-thin">

<section>
  <div class="section-head">
    <span class="label">source_artifacts</span>
    <span class="tag">// raw JSON hidden by default</span>
  </div>
  <div class="artifact-list">
    {% for artifact in model.artifacts %}
    <details class="artifact-details">
      <summary>
        <span>{{ artifact.label }}</span>
        <span class="badge">{{ artifact.status }}</span>
      </summary>
      <div class="kv artifact-kv">
        <span class="k">type</span>    <span class="v">{{ artifact.type }}</span>
        <span class="k">exists</span>  <span class="v">{{ artifact.exists }}</span>
        <span class="k">path</span>    <span class="v mono-token">{{ artifact.path }}</span>
        <span class="k">source</span>  <span class="v">{% if artifact.exists %}<a href="{{ artifact.source_href }}">open source artifact</a>{% else %}missing_or_unknown{% endif %}</span>
      </div>
      {% if artifact.raw_json %}
      <pre class="raw-json">{{ artifact.raw_json }}</pre>
      {% else %}
      <pre class="raw-json">raw JSON unavailable for this artifact.</pre>
      {% endif %}
    </details>
    {% endfor %}
  </div>
</section>

<hr class="rule-thin">

<section>
  <div class="section-head">
    <span class="label">what_to_do_next</span>
    <span class="tag">// no write actions</span>
  </div>
  <div class="next-steps">
    {% for step in model.next_steps %}
    <p class="next-step">{{ step }}</p>
    {% endfor %}
  </div>
</section>
{% endblock %}
