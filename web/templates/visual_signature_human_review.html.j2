{% extends "base.html.j2" %}
{% block title %}brand3 :: {{ model.title }}{% endblock %}
{% block extra_head %}
<script src="/static/visual_signature_human_review.js?v=brand3-human-review-draft-20260514" defer></script>
{% endblock %}
{% block content %}
<section>
  <div class="section-head">
    <span class="label">human_review</span>
    <span class="tag">// screenshot first · evidence-only · no persistence</span>
  </div>

  <h1 class="page-title">{{ model.title }}</h1>
  <p class="prose dim intro-copy vs-summary">{{ model.intro }}</p>

  <nav class="vs-nav" aria-label="Visual Signature sections">
    {% for item in model.nav %}
    <a class="vs-nav-link{% if item.active %} active{% endif %}" href="{{ item.href }}">{{ item.label }}</a>
    {% endfor %}
  </nav>

  <div class="guardrail-banner">
    <strong>Use visible evidence only.</strong>
    <span class="dim">This screen does not write review records, does not affect Brand3 Scoring, and does not call providers.</span>
  </div>

  <div class="badge-line">
    {% for guardrail in model.guardrails %}
    <span class="badge">{{ guardrail }}</span>
    {% endfor %}
  </div>
</section>

<hr class="rule-thin">

<section>
  <div class="section-head">
    <span class="label">review_queue</span>
    <span class="tag">// {{ model.queue["summary"].selected }} selected · {{ model.queue["summary"].pending }} pending</span>
  </div>

  <div class="human-review-queue" role="list">
    {% for item in model.queue["items"] %}
    <a class="human-review-queue-item{% if item.active %} is-active{% endif %}" href="{{ item.href }}" role="listitem">
      <span class="queue-title">{{ item.brand_name }}</span>
      <span class="queue-meta">{{ item.queue_state }} · {{ item.confidence_bucket }} · {{ item.category }}</span>
    </a>
    {% endfor %}
  </div>
</section>

<hr class="rule-thin">

<section>
  <div class="section-head">
    <span class="label">active_capture</span>
    <span class="tag">// {{ model.active.queue_id }}</span>
  </div>

  <div class="human-review-summary">
    <div>
      <h2>{{ model.active.brand_name }}</h2>
      <p class="dim">{{ model.active.website_url }}</p>
    </div>
    <div class="badge-line">
      <span class="badge badge-{{ model.active.queue_state|replace('_', '-') }}">{{ model.active.queue_state }}</span>
      <span class="badge">{{ model.active.confidence_bucket }}</span>
      <span class="badge">{{ model.active.perceptual_state }}</span>
      <span class="badge">{{ model.active.obstruction_type }}</span>
      <span class="badge">{{ model.active.obstruction_severity }}</span>
    </div>
  </div>

  <div class="vs-meta-row">
    <span class="inline-kv"><span class="k">capture_id</span>=<span class="v">{{ model.active.capture_id }}</span></span>
    <span class="inline-kv"><span class="k">category</span>=<span class="v">{{ model.active.category }}</span></span>
    <span class="inline-kv"><span class="k">dismissal_attempted</span>=<span class="v">{{ model.active.dismissal_attempted }}</span></span>
    <span class="inline-kv"><span class="k">dismissal_successful</span>=<span class="v">{{ model.active.dismissal_successful }}</span></span>
  </div>
</section>

<hr class="rule-thin">

<section class="human-review-evidence-section">
  <div class="section-head">
    <span class="label">visual_evidence</span>
    <span class="tag">// raw viewport is primary evidence</span>
  </div>

  {% if model.active.primary_variant and model.active.primary_variant.exists %}
  <figure class="human-review-primary-shot">
    <div class="human-review-primary-viewport">
      <img src="{{ model.active.primary_variant.href }}" alt="{{ model.active.primary_variant.alt }}">
    </div>
    <figcaption>
      <span>Primary evidence: {{ model.active.primary_variant.label }}</span>
      <code>{{ model.active.primary_variant.filename }}</code>
      <a class="source-link" href="{{ model.active.primary_variant.preview_href }}">preview</a>
      <a class="source-link" href="{{ model.active.primary_variant.href }}" target="_blank" rel="noopener">open full-resolution image</a>
    </figcaption>
  </figure>
  {% else %}
  <div class="visual-evidence-empty">Primary raw viewport evidence is missing.</div>
  {% endif %}

  <div class="human-review-variants" role="list">
    {% for screenshot in model.active.variants %}
    <figure class="human-review-variant{% if not screenshot.exists %} is-missing{% endif %}" role="listitem">
      {% if screenshot.exists %}
      <a href="{{ screenshot.preview_href }}" aria-label="Preview {{ screenshot.label }} screenshot for {{ model.active.brand_name }}">
        <img src="{{ screenshot.href }}" alt="{{ screenshot.alt }}">
      </a>
      {% else %}
      <div class="screenshot-missing">{% if screenshot.label == "clean attempt" %}No clean attempt available{% else %}missing screenshot{% endif %}</div>
      {% endif %}
      <figcaption>
        <span>{% if screenshot.label == "raw viewport" %}Primary evidence{% else %}Supplemental evidence{% endif %}: {{ screenshot.label }}</span>
        <code>{{ screenshot.filename }}</code>
      </figcaption>
    </figure>
    {% endfor %}
  </div>
</section>

<hr class="rule-thin">

<section>
  <div class="section-head">
    <span class="label">structured_visual_questions</span>
    <span class="tag">// answer from visible evidence only</span>
  </div>

  <div class="human-review-layout">
    <div class="human-review-question-stack">
      <div class="semantic-guidance-banner">
        <strong>Semantic guidance</strong>
        <span>{{ model.semantic_guidance.summary }}</span>
      </div>
      {% for group in model.question_groups %}
      <article class="human-review-question-group">
        <h2>{{ group.name }}</h2>
        {% for question in group.questions %}
        <div
          class="human-review-question"
          data-question-id="{{ question.id }}"
          data-question-text="{{ question.text }}"
          data-question-category="{{ question.category }}"
          data-observation-type="{{ question.observation_type }}"
          data-answer-type="{{ question.answer_type }}"
        >
          <div class="human-review-question-copy">
            <p>{{ question.text }}</p>
            <div class="semantic-chip-row" aria-label="semantic guidance for {{ question.text }}">
              <span class="semantic-chip">question category: {{ question.category_label }}</span>
              <span class="semantic-chip">observation type: {{ question.observation_type_label }}</span>
              <span class="semantic-chip">{{ question.answer_type_label }}</span>
            </div>
          </div>
          <div class="human-review-choice-row" aria-label="{{ question.text }}">
            <label class="choice-pill" title="{{ question.answer_guidance.yes }}">
              <input type="radio" name="answer_{{ question.id }}" value="yes">
              <span>yes</span>
            </label>
            <label class="choice-pill" title="{{ question.answer_guidance.partial }}">
              <input type="radio" name="answer_{{ question.id }}" value="partial">
              <span>partial</span>
            </label>
            <label class="choice-pill" title="{{ question.answer_guidance.no }}">
              <input type="radio" name="answer_{{ question.id }}" value="no">
              <span>no</span>
            </label>
            <label class="choice-pill" title="{{ question.answer_guidance.uncertain }}">
              <input type="radio" name="answer_{{ question.id }}" value="uncertain">
              <span>uncertain</span>
            </label>
          </div>
          <details class="semantic-details">
            <summary>What does this mean?</summary>
            <div class="semantic-details-grid">
              <span class="k">category</span>
              <span class="v">{{ question.category_label }} — {{ question.category_purpose }}</span>
              <span class="k">answer type</span>
              <span class="v">{{ question.answer_type_label }}</span>
              <span class="k">yes</span>
              <span class="v">{{ question.answer_guidance.yes }}</span>
              <span class="k">partial</span>
              <span class="v">{{ question.answer_guidance.partial }}</span>
              <span class="k">no</span>
              <span class="v">{{ question.answer_guidance.no }}</span>
              <span class="k">confidence</span>
              <span class="v">Confidence means reviewer certainty from the available evidence. {{ question.confidence_guidance }}</span>
              <span class="k">observation vs interpretation</span>
              <span class="v">{{ question.observation_interpretation_guidance }}</span>
            </div>
          </details>
        </div>
        {% endfor %}
      </article>
      {% endfor %}
    </div>

    <aside class="human-review-form-panel">
      <h2>Outcome draft</h2>
      <p class="dim">Local-only form. Nothing is persisted from this screen.</p>
      <div class="draft-warning" role="note">
        <strong>This is not an official review record.</strong>
        <span>Exported drafts must be validated before ingestion.</span>
      </div>
      <form
        class="human-review-form"
        data-human-review-draft-form
        data-brand-name="{{ model.active.brand_name }}"
        data-capture-id="{{ model.active.capture_id }}"
        data-queue-id="{{ model.active.queue_id }}"
      >
        {% for ref in model.active.evidence_refs %}
        <input type="hidden" name="evidence_ref" value="{{ ref }}">
        {% endfor %}
        <label>
          <span>Reviewer ID</span>
          <input type="text" name="reviewer_id" placeholder="reviewer-01" autocomplete="off">
        </label>
        <label>
          <span>Review outcome</span>
          <select name="review_outcome">
            {% for outcome in model.outcomes %}
            <option value="{{ outcome }}">{{ outcome }}</option>
            {% endfor %}
          </select>
        </label>
        <label>
          <span>Confidence</span>
          <select name="confidence_bucket">
            {% for bucket in model.confidence_buckets %}
            <option value="{{ bucket }}" {% if bucket == model.active.confidence_bucket %}selected{% endif %}>{{ bucket }}</option>
            {% endfor %}
          </select>
        </label>
        <label>
          <span>Notes</span>
          <textarea name="notes" placeholder="Short evidence-based note."></textarea>
        </label>
        <label>
          <span>Contradiction notes</span>
          <textarea name="contradictions" placeholder="Required when visible evidence contradicts the claim."></textarea>
        </label>
        <label>
          <span>Additional evidence needed</span>
          <textarea name="missing_evidence" placeholder="What would resolve uncertainty?"></textarea>
        </label>
        <div class="draft-actions">
          <button class="button" type="button" data-export-draft-review>Export draft review JSON</button>
          <span class="draft-export-status" data-draft-export-status aria-live="polite"></span>
        </div>
      </form>
    </aside>
  </div>
</section>

<hr class="rule-thin">

<section>
  <div class="section-head">
    <span class="label">review_record_preview</span>
    <span class="tag">// no completed record generated</span>
  </div>

  <div class="artifact-details">
    <p class="dim">Preview only. No review record is persisted from this screen in the current phase.</p>
    <div class="kv artifact-kv">
      {% for field in model.record_preview_fields %}
      <span class="k">{{ field }}</span>    <span class="v">{% if field == "queue_id" %}{{ model.active.queue_id }}{% elif field == "capture_id" %}{{ model.active.capture_id }}{% elif field == "evidence_refs" %}selected screenshot refs{% else %}local draft field{% endif %}</span>
      {% endfor %}
    </div>
  </div>
</section>

<hr class="rule-thin">

<section>
  <div class="section-head">
    <span class="label">advanced_metadata</span>
    <span class="tag">// collapsed by default</span>
  </div>

  <details class="artifact-details">
    <summary>
      <span>source artifacts and evidence notes</span>
      <span class="badge">collapsed</span>
    </summary>
    {% if model.active.evidence_notes %}
    <ul class="evidence-notes">
      {% for note in model.active.evidence_notes %}
      <li>{{ note }}</li>
      {% endfor %}
    </ul>
    {% endif %}
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>artifact</th>
            <th>status</th>
            <th>path</th>
          </tr>
        </thead>
        <tbody>
          {% for artifact in model.source_artifacts %}
          <tr>
            <td>{{ artifact.label }}</td>
            <td><span class="badge">{{ artifact.status }}</span></td>
            <td class="mono-token">{{ artifact.path }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </details>
</section>
{% endblock %}
