{% extends "base.html.j2" %}
{% block title %}brand3 :: takedown{% endblock %}
{% block content %}
<section>
  <div class="section-head">
    <span class="label">takedown_request</span>
    <span class="tag">// manual process</span>
  </div>

  <p class="prose">
    If you own a brand analyzed by Brand3 and want the public report removed, email
    <a href="mailto:hola@floc.com?subject=Brand3 takedown request — {{ domain or 'your-brand.com' }}&body=Hi FLOC,%0A%0AI own {{ domain or 'your-brand.com' }} and request the removal of the Brand3 analysis from the public observatory.%0A%0AThanks.">hola@floc.com</a>
    with the brand domain and proof of ownership (matching email on the public whois or the brand's contact page).
  </p>

  <p class="prose dim">
    Requests are processed manually. We respond within 5 business days and remove the report once ownership is verified.
    The raw analysis record is kept internally for quality control but is no longer public.
  </p>

  <p class="small dim" style="margin-top:14px"><a href="/">← back</a></p>
</section>
{% endblock %}
