<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>brand-audit :: {{ brand.url or brand.name }}{% if theme == 'dark' %} · night{% endif %}</title>
<style>
  :root {
  {%- if theme == 'dark' %}
    --fg: #d6d3cc;
    --fg-bright: #f2efe7;
    --bg: #0e0f10;
    --panel: #121314;
    --muted: #6a6963;
    --rule: #2a2b2d;
    --alert: #e06b5c;
    --ok: #8fbf6a;
    --warn: #e0c26b;
    --accent: #6fa8c9;
    --key: #b58a6a;
    --chip-bg: #15171a;
    --chip-border: #333336;
  {%- else %}
    --fg: #111111;
    --fg-bright: #111111;
    --bg: #fafaf7;
    --panel: #fafaf7;
    --muted: #6b6b6b;
    --rule: #111111;
    --alert: #a8261c;
    --ok: #1f5d3a;
    --warn: #9a7a00;
    --accent: #111111;
    --key: #6b6b6b;
    --chip-bg: #f2f0ea;
    --chip-border: #c9c6bf;
  {%- endif %}
  }
  * { box-sizing: border-box; }
  html, body {
    margin: 0; padding: 0;
    background: var(--bg); color: var(--fg);
    font-family: "IBM Plex Mono", "JetBrains Mono", "Menlo", "Consolas", ui-monospace, monospace;
    font-size: 13px; line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    font-feature-settings: "liga" 0, "calt" 0;
  }
  .page { max-width: 920px; margin: 0 auto; padding: 40px 28px 80px; }
  .term-head { white-space: pre-wrap; margin: 0 0 6px; font-family: inherit; font-size: 13px; line-height: 1.55; }
  .prompt {
    color: {% if theme == 'dark' %}var(--ok){% else %}var(--muted){% endif %};
    user-select: none;
    {% if theme == 'dark' %}font-weight: 700;{% endif %}
  }
  .dim { color: var(--muted); }
  .rule { border: 0; border-top: 1px solid var(--rule); margin: 18px 0; }
  .rule-thin { border: 0; border-top: 1px dashed {% if theme == 'dark' %}var(--rule){% else %}#bdbdbd{% endif %}; margin: 14px 0; }
  h1, h2, h3, h4 { font-size: 13px; font-weight: 700; margin: 0; letter-spacing: 0; color: var(--fg-bright); }
  h4 { margin-top: 14px; }
  .section-head {
    display: flex; justify-content: space-between; align-items: baseline;
    gap: 12px; margin: 28px 0 10px;
  }
  .section-head .tag { color: var(--muted); font-weight: 400; }
  .section-head .label { text-transform: uppercase; font-weight: 700; }
  table { width: 100%; border-collapse: collapse; font-family: inherit; font-size: 13px; }
  th, td { text-align: left; padding: 4px 10px 4px 0; vertical-align: top; font-weight: 400; }
  th { border-bottom: 1px solid {% if theme == 'dark' %}var(--rule){% else %}var(--fg){% endif %}; font-weight: 700; color: var(--fg-bright); }
  td.num { text-align: right; white-space: nowrap; padding-right: 18px; }
  td.bar { font-family: inherit; white-space: pre; color: var(--fg); }
  td.verdict { color: var(--muted); }

  /* Header meta — fixed-width label column so values never concatenate. */
  dl.report-meta {
    display: grid;
    grid-template-columns: 180px 1fr;
    row-gap: 2px; column-gap: 12px;
    margin: 0;
  }
  dl.report-meta dt { color: {% if theme == 'dark' %}var(--key){% else %}var(--muted){% endif %}; margin: 0; }
  dl.report-meta dd { margin: 0; color: var(--fg); }

  .score-huge { font-size: 74px; line-height: 1; font-weight: 700; letter-spacing: -2px; margin: 6px 0 0; }
  .score-scale { color: var(--muted); font-size: 12px; }
  .header-grid { display: grid; grid-template-columns: 1fr auto; gap: 32px; align-items: end; }

  .prose { max-width: 78ch; }
  .num-inline { font-variant-numeric: tabular-nums; }

  .quality-note {
    margin-top: 12px;
    padding: 10px 12px;
    border: 1px solid var(--rule);
    background: var(--chip-bg);
    color: var(--fg);
  }
  .quality-note strong { color: var(--fg-bright); }
  .quality-note.warn { border-color: var(--warn); }
  .quality-note.alert { border-color: var(--alert); }

  .tabs {
    margin-top: 24px;
  }
  .tab-list {
    display: flex;
    gap: 8px;
    margin-bottom: 18px;
  }
  .tab-button {
    appearance: none;
    background: transparent;
    color: var(--muted);
    border: 1px solid var(--chip-border);
    padding: 6px 12px;
    font: inherit;
    cursor: pointer;
  }
  .tab-button[aria-selected="true"] {
    color: var(--fg-bright);
    border-color: var(--accent);
    background: var(--chip-bg);
  }
  .tab-panel[hidden] { display: none; }

  .legacy-section { margin: 18px 0; }
  .legacy-block { margin: 10px 0 14px; }
  .legacy-block p { margin: 4px 0 6px; }
  .quote-list { list-style: none; padding: 0; margin: 6px 0 0; }
  .quote-list li { margin: 0 0 8px; }
  .quote { color: var(--fg); }
  .quote-meta { color: var(--muted); font-size: 12px; }
  .source-list { list-style: none; padding: 0; margin: 0; }
  .source-list li { margin: 0 0 6px; word-break: break-all; }

  /* Findings (§3) */
  .dimension { margin: 18px 0; }
  .finding { margin: 10px 0 14px; }
  .finding h4 { color: var(--fg-bright); }
  .finding p { margin: 4px 0 6px; color: var(--fg); }
  ul.chips { list-style: none; padding: 0; margin: 6px 0 0; display: flex; flex-wrap: wrap; gap: 6px; }
  ul.chips li { margin: 0; }
  ul.chips a {
    display: inline-block;
    padding: 2px 8px;
    border: 1px solid var(--chip-border);
    background: var(--chip-bg);
    color: var(--fg);
    font-size: 12px; line-height: 1.4;
    text-decoration: none;
    word-break: break-all;
  }
  ul.chips a:hover { border-color: var(--accent); color: var(--fg-bright); }

  /* Sources (§5) collapsible */
  details.sources summary {
    cursor: pointer;
    color: var(--muted);
    padding: 4px 0;
    list-style: revert;
  }
  details.sources summary:hover { color: var(--fg-bright); }
  details.sources[open] summary { margin-bottom: 8px; }
  details.sources h3 { font-weight: 700; margin: 10px 0 4px; color: var(--fg-bright); }
  details.sources ul { list-style: none; padding: 0; margin: 0 0 6px; }
  details.sources li { color: var(--fg); padding: 1px 0; word-break: break-all; }

  .badge {
    display: inline-block; border: 1px solid var(--fg); padding: 0 6px;
    font-size: 12px; text-transform: uppercase; letter-spacing: 0.04em;
    font-weight: 700; color: var(--fg-bright);
  }
  .badge.warn { border-color: var(--alert); color: var(--alert); }
  .badge.ok { border-color: var(--ok); color: var(--ok); }
  .hl-alert { color: var(--alert); }
  .hl-ok { color: var(--ok); }
  .hl-warn { color: var(--warn); }
  .hl-accent { color: var(--accent); }
  .empty { color: var(--muted); font-style: normal; }
  .small { font-size: 12px; color: var(--muted); }

  .footer {
    margin-top: 40px; padding-top: 12px;
    border-top: 1px solid {% if theme == 'dark' %}var(--rule){% else %}var(--fg){% endif %};
    color: var(--muted); font-size: 12px;
  }
  .cursor {
    display: inline-block; width: 7px; height: 14px;
    background: {% if theme == 'dark' %}var(--ok){% else %}var(--fg){% endif %};
    vertical-align: -2px;
    animation: blink 1.05s steps(1, end) infinite;
    margin-left: 4px;
  }
  @keyframes blink { 0%, 55% { opacity: 1; } 56%, 100% { opacity: 0; } }
  a { color: inherit; text-decoration: underline; text-underline-offset: 2px; }

  @media (max-width: 640px) {
    .header-grid { grid-template-columns: 1fr; }
    dl.report-meta { grid-template-columns: 120px 1fr; }
    .score-huge { font-size: 56px; }
  }
  @media print {
    body { background: #fff; }
    .cursor { display: none; }
  }
</style>
</head>
<body>
<div class="page">

<pre class="term-head"><span class="prompt">{% if theme == 'dark' %}❯{% else %}${% endif %}</span> brand-audit <span class="hl-accent">--target</span> {{ brand.url or brand.name }} <span class="hl-accent">--profile</span> {{ brand.profile }} <span class="hl-accent">--engine</span> {{ footer.engine }}
{%- for line in term_lines %}
<span class="hl-{{ line.level }}">[{{ line.level }}]</span>{% if line.level == 'ok' %}   {% else %} {% endif %}<span class="dim">{{ line.text }}</span>
{%- endfor %}</pre>

<hr class="rule">

<div class="header-grid">
  <dl class="report-meta">
    <dt>brand</dt>
    <dd>{{ brand.name }}</dd>
    <dt>url</dt>
    <dd>{% if brand.url %}<a href="{{ brand.url }}" target="_blank" rel="noopener">{{ brand.url }}</a>{% else %}<span class="empty">(no url)</span>{% endif %}</dd>
    <dt>analysis_date</dt>
    <dd>{{ brand.analysis_date or 'n/a' }}</dd>
    <dt>profile</dt>
    <dd>{{ brand.profile }}{% if brand.profile_source %} · source={{ brand.profile_source }}{% endif %}</dd>
    <dt>data_quality</dt>
    <dd>{{ brand.data_quality }}</dd>
    <dt>scope</dt>
    <dd>public web surface + organic mentions (no paid)</dd>
  </dl>
  <div style="text-align:right">
    <div class="small">SCORE_GLOBAL</div>
    <div class="score-huge num-inline">{{ score.global_display }}</div>
    <div class="score-scale">/ 100 · <span class="dim">band: {{ score.band_letter }} · "{{ score.band_adjective }}"</span></div>
  </div>
</div>

<hr class="rule">

<div class="section-head">
  <span class="label">§1B  estado de confianza</span>
  <span class="tag">// {{ evaluation.overall_status }}</span>
</div>
<table>
  <tbody>
    <tr>
      <th style="width:28%">estado agregado</th>
      <td>
        {%- if evaluation.overall_status == 'insufficient_data' -%}
          <span class="hl-alert">{{ evaluation.overall_status_label }}</span>
        {%- elif evaluation.overall_status == 'degraded' -%}
          <span class="hl-warn">{{ evaluation.overall_status_label }}</span>
        {%- else -%}
          <span class="hl-ok">{{ evaluation.overall_status_label }}</span>
        {%- endif -%}
      </td>
    </tr>
    <tr>
      <th>dimensiones</th>
      <td>
        good: {{ evaluation.dimension_status_counts.good }},
        degraded: {{ evaluation.dimension_status_counts.degraded }},
        insufficient: {{ evaluation.dimension_status_counts.insufficient_data }}
      </td>
    </tr>
    <tr>
      <th>motivo</th>
      <td>{{ evaluation.overall_reason_label }}</td>
    </tr>
    {%- if trust_summary.limited_dimensions %}
    <tr>
      <th>dimensiones limitadas</th>
      <td>
        {%- for dim in trust_summary.limited_dimensions[:5] -%}
          {{ dim.display_name or dim.name }}{% if not loop.last %}, {% endif %}
        {%- endfor -%}
      </td>
    </tr>
    {%- endif %}
    {%- if cost_policy.available %}
    <tr>
      <th>coste / ejecución</th>
      <td>
        inputs: {% if cost_policy.raw_input_sources %}{{ cost_policy.raw_input_sources | join(', ') }}{% else %}<span class="dim">no persistidos</span>{% endif %}
        {%- if cost_policy.skipped -%}
          ; omitido:
          {%- for name, reason in cost_policy.skipped.items() -%}
            {{ name }}={{ reason }}{% if not loop.last %}, {% endif %}
          {%- endfor -%}
        {%- endif -%}
      </td>
    </tr>
    {%- endif %}
  </tbody>
</table>

<hr class="rule">

<div class="section-head">
  <span class="label">§2  scores by dimension</span>
  <span class="tag">// 0-100 · bars = 5%/block</span>
</div>

<table>
  <thead>
    <tr>
      <th style="width: 20%">dimension</th>
      <th style="width: 8%" class="num">score</th>
      <th style="width: 28%">bar</th>
      <th style="width: 12%">confianza</th>
      <th style="width: 12%">cobertura</th>
      <th>verdict</th>
    </tr>
  </thead>
  <tbody>
  {%- for dim in dimensions %}
    <tr>
      <td>{{ dim.display_name }}</td>
      <td class="num num-inline">{% if dim.badge_type == 'warn' %}<span class="hl-alert">{{ dim.score_display }}</span>{% else %}{{ dim.score_display }}{% endif %}</td>
      <td class="bar">{% if dim.badge_type == 'warn' %}<span class="hl-alert">{{ dim.bar }}</span>{% else %}{{ dim.bar }}{% endif %}</td>
      <td class="verdict">{% if dim.confidence_status == 'insufficient_data' %}<span class="hl-alert">{{ dim.confidence_label }}</span>{% else %}{{ dim.confidence_label }}{% endif %}</td>
      <td class="verdict">{{ dim.coverage_label }}</td>
      <td class="verdict">{{ dim.short_verdict }}</td>
    </tr>
  {%- endfor %}
  </tbody>
</table>

{%- set limited_dimensions = trust_summary.limited_dimensions or [] -%}
{%- if limited_dimensions %}
<div class="quality-note warn">
  <strong>Lectura condicionada por evidencia incompleta.</strong>
  {%- for dim in limited_dimensions[:3] %}
    <div class="quote-meta">
      {{ dim.display_name or dim.name }}:
      confianza {{ dim.confidence_label }}, cobertura {{ dim.coverage_label }}
      {%- if dim.confidence_reason_labels %}; {{ dim.confidence_reason_labels[:2] | join(', ') }}{% endif -%}
      {%- if dim.missing_signals %}; faltan {{ dim.missing_signals[:3] | join(', ') }}{% endif -%}
      {%- if dim.recommended_next_steps %}; siguiente: {{ dim.recommended_next_steps[0] }}{% endif -%}
    </div>
  {%- endfor %}
</div>
{%- endif %}

<hr class="rule">

{%- if evidence_summary %}
<div class="section-head">
  <span class="label">§2C  resumen de evidencia</span>
  <span class="tag">// {{ evidence_summary.total }} items</span>
</div>
<table>
  <tbody>
    <tr>
      <th style="width:28%">evidencia total</th>
      <td>{{ evidence_summary.total }}</td>
    </tr>
    <tr>
      <th>fuentes</th>
      <td>
        {%- if evidence_summary.by_source -%}
          {%- for source, count in evidence_summary.by_source.items() -%}
            {{ source }}: {{ count }}{% if not loop.last %}, {% endif %}
          {%- endfor -%}
        {%- else -%}
          <span class="dim">sin evidencia trazable</span>
        {%- endif -%}
      </td>
    </tr>
    <tr>
      <th>calidad</th>
      <td>
        {%- if evidence_summary.by_quality -%}
          {%- for quality, count in evidence_summary.by_quality.items() -%}
            {{ quality }}: {{ count }}{% if not loop.last %}, {% endif %}
          {%- endfor -%}
        {%- else -%}
          <span class="dim">sin clasificar</span>
        {%- endif -%}
      </td>
    </tr>
    <tr>
      <th>sin evidencia</th>
      <td>{% if evidence_summary.dimensions_without_evidence %}<span class="hl-alert">{{ evidence_summary.dimensions_without_evidence | join(', ') }}</span>{% else %}ninguna dimensión{% endif %}</td>
    </tr>
  </tbody>
</table>
<hr class="rule">
{%- endif %}

{%- if context_readiness.available %}
<div class="section-head">
  <span class="label">§2B  legibilidad IA/buscadores</span>
  <span class="tag">// context readiness</span>
</div>

  {%- if context_readiness.status == 'insufficient_data' %}
  <div class="quality-note alert">
    <strong>Datos insuficientes para una puntuación defendible.</strong>
    El pre-scan encontró muy poca cobertura contextual; las conclusiones deben tratarse como parciales.
  </div>
  {%- elif context_readiness.confidence < 0.6 %}
  <div class="quality-note warn">
    <strong>Lectura contextual limitada.</strong>
    Las señales existen, pero la confianza es baja/media.
  </div>
  {%- endif %}
  <table>
    <tbody>
      <tr>
        <th style="width:28%">sitemap</th>
        <td>{% if context_readiness.sitemap_found %}encontrado · {{ context_readiness.sitemap_url_count }} URLs{% else %}<span class="hl-alert">no encontrado</span>{% endif %}</td>
      </tr>
      <tr>
        <th>robots</th>
        <td>{% if context_readiness.robots_found %}encontrado{% else %}<span class="hl-alert">no encontrado</span>{% endif %}</td>
      </tr>
      <tr>
        <th>llms.txt</th>
        <td>{% if context_readiness.llms_txt_found %}encontrado{% else %}<span class="dim">no encontrado</span>{% endif %}</td>
      </tr>
      <tr>
        <th>schema</th>
        <td>{% if context_readiness.schema_types %}{{ context_readiness.schema_types[:8] | join(', ') }}{% else %}<span class="dim">sin schema detectado</span>{% endif %}</td>
      </tr>
      <tr>
        <th>páginas clave</th>
        <td>
          {%- set found_pages = [] -%}
          {%- for name, found in context_readiness.key_pages.items() -%}
            {%- if found -%}{%- set _ = found_pages.append(name) -%}{%- endif -%}
          {%- endfor -%}
          {% if found_pages %}{{ found_pages | join(', ') }}{% else %}<span class="dim">ninguna detectada</span>{% endif %}
        </td>
      </tr>
      <tr>
        <th>cobertura / confianza</th>
        <td>{{ context_readiness.coverage_label }} / {{ context_readiness.confidence_label }}</td>
      </tr>
    </tbody>
  </table>

<hr class="rule">
{%- endif %}

{%- if evaluation.data_quality == 'degraded' %}
<div class="quality-note warn">
  <strong>Evaluation degraded.</strong> Some primary inputs were incomplete, so parts of this analysis rely on fallback evidence or partial coverage.
</div>
{%- elif evaluation.data_quality == 'insufficient' %}
<div class="quality-note alert">
  <strong>Insufficient data.</strong> This run could not evaluate the full brand surface reliably. Read any conclusions as partial.
</div>
{%- endif %}

<div class="tabs" data-tabs>
  <div class="tab-list" role="tablist" aria-label="Analysis views">
    <button class="tab-button" type="button" role="tab" id="tab-actual" aria-controls="panel-actual" aria-selected="false" data-tab-target="actual">Actual</button>
    <button class="tab-button" type="button" role="tab" id="tab-new" aria-controls="panel-new" aria-selected="true" data-tab-target="new">Nueva</button>
  </div>

  <section class="tab-panel" id="panel-actual" role="tabpanel" aria-labelledby="tab-actual" hidden>
    <div class="section-head">
      <span class="label">§3A  current reading</span>
      <span class="tag">// analytical view</span>
    </div>
    <div class="prose">{{ legacy_summary }}</div>

    <hr class="rule">

    <div class="section-head">
      <span class="label">§4A  observations by dimension</span>
      <span class="tag">// direct signals</span>
    </div>
    {%- for dim in dimensions %}
    <section class="legacy-section">
      <h3>{{ loop.index }}. {{ dim.display_name }} <span class="dim">· {{ dim.score_display }}/100 · {{ dim.short_verdict }}</span></h3>
      {%- if dim.observations %}
        <ul class="quote-list">
          {%- for observation in dim.observations %}
          <li><span class="quote">{{ observation }}</span></li>
          {%- endfor %}
        </ul>
      {%- else %}
        <p class="empty">no derived observations for this dimension.</p>
      {%- endif %}
    </section>
    {%- if not loop.last %}
    <hr class="rule-thin">
    {%- endif %}
    {%- endfor %}

    <hr class="rule">

    <div class="section-head">
      <span class="label">§5A  evidence by dimension</span>
      <span class="tag">// raw support</span>
    </div>
    {%- for dim in dimensions %}
    <section class="legacy-section">
      <h3>{{ loop.index }}. {{ dim.display_name }}</h3>
      {%- if dim.evidence %}
        <ul class="quote-list">
          {%- for item in dim.evidence %}
          <li>
            {%- if item.quote %}
            <div class="quote">{{ item.quote }}</div>
            {%- endif %}
            {%- if item.source_url %}
            <div class="quote-meta"><a href="{{ item.source_url }}" target="_blank" rel="noopener">{{ item.source_url }}</a></div>
            {%- endif %}
          </li>
          {%- endfor %}
        </ul>
      {%- else %}
        <p class="empty">no direct evidence collected for this dimension.</p>
      {%- endif %}
    </section>
    {%- if not loop.last %}
    <hr class="rule-thin">
    {%- endif %}
    {%- endfor %}

    <hr class="rule">

    <div class="section-head">
      <span class="label">§6A  all consulted sources</span>
      <span class="tag">// {{ all_sources | length }} total</span>
    </div>
    {%- if all_sources %}
    <ul class="source-list">
      {%- for url in all_sources %}
      <li><a href="{{ url }}" target="_blank" rel="noopener">{{ url }}</a></li>
      {%- endfor %}
    </ul>
    {%- else %}
    <p class="empty">no citable URLs were collected in this run.</p>
    {%- endif %}
  </section>

  <section class="tab-panel" id="panel-new" role="tabpanel" aria-labelledby="tab-new">
    <div class="section-head">
      <span class="label">§3N  synthesis</span>
      <span class="tag">// overview</span>
    </div>
    <div class="prose">{{ synthesis_prose }}</div>

    <hr class="rule">

    <div class="section-head">
      <span class="label">§4N  findings by dimension</span>
      <span class="tag">// consolidated evidence</span>
    </div>

    {%- for dim in dimensions %}
    <section class="dimension">
      <h3>4.{{ loop.index }}  {{ dim.display_name }} <span class="dim">· {{ dim.score_display }}/100 · {{ dim.short_verdict }} · {{ dim.verdict_adjective }}</span></h3>
      {%- if dim.findings %}
        {%- for finding in dim.findings %}
        <div class="finding">
          <h4>{{ finding.title }}</h4>
          <p>{{ finding.prose }}</p>
          {%- if finding.evidence_urls %}
          <ul class="chips">
            {%- for url in finding.evidence_urls %}
            <li><a href="{{ url }}" target="_blank" rel="noopener">{{ url | chip_label }}</a></li>
            {%- endfor %}
          </ul>
          {%- endif %}
        </div>
        {%- endfor %}
      {%- else %}
        <p class="empty">insufficient data to generate findings for this dimension.</p>
      {%- endif %}
    </section>
    {%- if not loop.last %}
    <hr class="rule-thin">
    {%- endif %}
    {%- endfor %}

    {%- if tensions_prose %}
    <hr class="rule">

    <div class="section-head">
      <span class="label">§5N  cross-dimension tensions</span>
      <span class="tag">// one observation</span>
    </div>
    <div class="prose">{{ tensions_prose }}</div>
    {%- endif %}

    <hr class="rule">

    <div class="section-head">
      <span class="label">§6N  grouped sources</span>
      <span class="tag">// {{ all_sources | length }} total</span>
    </div>

    {%- if all_sources %}
    <details class="sources">
      <summary>show all sources ({{ all_sources | length }})</summary>
      {%- for group_label, urls in sources_grouped.items() %}
      <h3>{{ group_label }}</h3>
      <ul>
        {%- for url in urls %}
        <li><a href="{{ url }}" target="_blank" rel="noopener">{{ url }}</a></li>
        {%- endfor %}
      </ul>
      {%- endfor %}
    </details>
    {%- else %}
    <p class="empty">no citable URLs were collected in this run.</p>
    {%- endif %}
  </section>
</div>

<hr class="rule">

<div class="footer">
  <dl class="report-meta">
    <dt>engine</dt>
    <dd>{{ footer.engine }}</dd>
    <dt>profile</dt>
    <dd>{{ footer.profile }}</dd>
    <dt>fingerprint</dt>
    <dd>{{ footer.fingerprint }}</dd>
    <dt>runtime</dt>
    <dd>{{ footer.runtime }}</dd>
    <dt>report_id</dt>
    <dd>{{ footer.report_id }}</dd>
  </dl>
  <div style="margin-top:14px" class="small">
    This analysis was automatically generated by Brand3 using public data.
    The scores are opinions derived from heuristics and LLM analysis, not facts.
    If you own this brand and want the analysis removed, see <a href="/takedown">/takedown</a>.
  </div>
  <div style="margin-top:10px"><span class="prompt">{% if theme == 'dark' %}❯{% else %}${% endif %}</span> _<span class="cursor"></span></div>
</div>

</div>
<script>
(() => {
  const root = document.querySelector('[data-tabs]');
  if (!root) return;
  const buttons = Array.from(root.querySelectorAll('[data-tab-target]'));
  const panels = {
    actual: root.querySelector('#panel-actual'),
    new: root.querySelector('#panel-new'),
  };
  function activate(name) {
    buttons.forEach((button) => {
      const active = button.dataset.tabTarget === name;
      button.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    Object.entries(panels).forEach(([key, panel]) => {
      if (!panel) return;
      panel.hidden = key !== name;
    });
  }
  buttons.forEach((button) => {
    button.addEventListener('click', () => activate(button.dataset.tabTarget));
  });
  activate('new');
})();
</script>
</body>
</html>
