# Brand3 local development environment.
#
# Copy to `.env` for local work:
#   cp .env.example .env
#
# Never commit `.env` or real secrets.

# Provider keys
FIRECRAWL_API_KEY=your-firecrawl-api-key-here
EXA_API_KEY=your-exa-api-key-here

# LLM provider (OpenAI-compatible). Default: Google AI Studio + Gemini 2.5 Flash.
# Get a key at https://aistudio.google.com/apikey.
# GEMINI_API_KEY / GOOGLE_API_KEY / OPENROUTER_API_KEY are accepted as fallbacks.
BRAND3_LLM_API_KEY=your-aistudio-key-here

# LLM model roles:
# default = standard scoring
# cheap = high-volume extraction / low-risk checks
# premium = final narrative / complex validation
# vision = screenshot analysis
BRAND3_LLM_MODEL=gemini-2.5-flash
BRAND3_LLM_CHEAP_MODEL=gemini-2.5-flash-lite
BRAND3_LLM_PREMIUM_MODEL=gemini-2.5-pro
BRAND3_VISION_MODEL=gemini-2.5-flash

# Screenshot capture provider:
# playwright = default local browser screenshot capture, no Firecrawl credits required
# firecrawl = optional legacy screenshot path
SCREENSHOT_PROVIDER=playwright

# Local SQLite database. The default app path is data/brand3.sqlite3.
# Keep local DB files out of Git.
# BRAND3_DB_PATH=data/brand3.sqlite3

# FastAPI/Jinja local app settings.
BRAND3_ENVIRONMENT=development
BRAND3_BASE_URL=http://127.0.0.1:8000
BRAND3_MAX_CONCURRENT_ANALYSES=2
BRAND3_ANALYSIS_TIMEOUT_SECONDS=600
BRAND3_RATE_LIMIT_PER_IP=5
BRAND3_RATE_LIMIT_WINDOW_HOURS=24
BRAND3_RATE_LIMIT_BYPASS_IPS=127.0.0.1,::1

# Team access. Use generated local-only values in `.env`.
BRAND3_TEAM_TOKEN=replace-with-local-team-token
BRAND3_COOKIE_SECRET=replace-with-at-least-32-random-characters

# Optional override for the read-only Visual Signature artifact root.
# BRAND3_VISUAL_SIGNATURE_ROOT=examples/visual_signature

# Override to use a different provider (e.g. OpenRouter):
# BRAND3_LLM_BASE_URL=https://openrouter.ai/api/v1
# BRAND3_LLM_MODEL=google/gemini-2.5-flash
# BRAND3_LLM_CHEAP_MODEL=google/gemini-2.5-flash-lite
# BRAND3_LLM_PREMIUM_MODEL=google/gemini-2.5-pro
# BRAND3_VISION_MODEL=google/gemini-2.5-flash
