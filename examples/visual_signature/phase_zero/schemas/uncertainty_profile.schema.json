{
  "additionalProperties": false,
  "properties": {
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "confidence_level": {
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "title": "Confidence Level",
      "type": "string"
    },
    "known_unknowns": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Known Unknowns",
      "type": "array"
    },
    "record_type": {
      "const": "uncertainty_profile",
      "title": "Record Type",
      "type": "string"
    },
    "reviewer_required": {
      "default": false,
      "title": "Reviewer Required",
      "type": "boolean"
    },
    "schema_version": {
      "const": "phase-zero-uncertainty-profile-1",
      "title": "Schema Version",
      "type": "string"
    },
    "taxonomy_version": {
      "const": "phase-zero-taxonomy-1",
      "title": "Taxonomy Version",
      "type": "string"
    },
    "uncertainty_reasons": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Uncertainty Reasons",
      "type": "array"
    },
    "unsupported_inference": {
      "default": false,
      "title": "Unsupported Inference",
      "type": "boolean"
    }
  },
  "required": [
    "schema_version",
    "taxonomy_version",
    "record_type",
    "confidence",
    "confidence_level"
  ],
  "title": "UncertaintyProfile",
  "type": "object"
}
